# Copiar este archivo a .env y rellenar los valores reales (nunca versionar .env)

# Django
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-secreta-larga
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos PostgreSQL
DB_NAME=mia_db
DB_USER=mia_user
DB_PASSWORD=cambia-esto
DB_HOST=localhost
DB_PORT=5432

# Rutas de modelos PLN (sin barra al final)
MODELO_SPACY=es_core_news_md
MODELO_EMBEDDINGS=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
MODELOS_DIR=modelos/

# Semilla aleatoria para reproducibilidad
SEMILLA_ALEATORIA=42
